# Identifiants partagés par l'équipe (obligatoire en production)
TABLEAU_USER=equipe
TABLEAU_PASSWORD=changez-moi-maintenant

# Secret de session (optionnel — dérivé du mot de passe si absent)
# TABLEAU_SESSION_SECRET=

# Base de données (Railway/Render : /data/data.db)
# DB_PATH=./data.db

# Port (Railway définit PORT automatiquement)
# PORT=5000
